---
import { siteConfig } from "../config";
---

<section id="chi-sono" class="pt-10 pb-20 md:pt-14 md:pb-28 bg-white relative overflow-hidden">
  <!-- Decorative: large faded quote mark -->
  <div class="absolute top-8 right-8 md:right-16 font-['Playfair_Display',serif] text-[200px] md:text-[300px] leading-none text-[var(--color-surface)] select-none pointer-events-none">"</div>

  <div class="max-w-5xl mx-auto px-6 relative">
    <div class="grid md:grid-cols-12 gap-8 md:gap-12">
      <!-- Label column -->
      <div class="md:col-span-3 reveal-left">
        <p class="text-[var(--color-accent)] text-xs tracking-[0.25em] uppercase font-semibold mb-3" data-lang data-it="Chi Sono" data-es="Sobre Mí">Chi Sono</p>
        <div class="w-12 h-0.5 bar-shimmer rounded-full mb-6"></div>

        <!-- Mini stats -->
        <div class="space-y-4 mt-8">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-[var(--color-surface)] flex items-center justify-center">
              <span class="text-xs">🇵🇪</span>
            </div>
            <span class="text-xs text-[var(--color-primary)]" data-lang data-it="Peruviana di nascita" data-es="Peruana de nacimiento">Peruviana di nascita</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-[var(--color-surface)] flex items-center justify-center">
              <span class="text-xs">🇮🇹</span>
            </div>
            <span class="text-xs text-[var(--color-primary)]" data-lang data-it="Basata in Italia" data-es="Basada en Italia">Basata in Italia</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-[var(--color-surface)] flex items-center justify-center">
              <span class="text-xs">✦</span>
            </div>
            <span class="text-xs text-[var(--color-primary)]" data-lang data-it="Contenuti & Strategia" data-es="Contenido & Estrategia">Contenuti & Strategia</span>
          </div>
        </div>
      </div>

      <!-- Bio + Quote column -->
      <div class="md:col-span-9">
        <div class="grid md:grid-cols-2 gap-8">
          <!-- Bio -->
          <div class="reveal stagger-1">
            <p class="text-[var(--color-primary-dark)]/80 leading-relaxed text-[15px]" data-lang data-it={siteConfig.about.it} data-es={siteConfig.about.es}>
              {siteConfig.about.it}
            </p>
          </div>

          <!-- Quote card -->
          <div class="reveal-right stagger-2">
            <div class="bg-[var(--color-surface)] rounded-2xl p-8 relative">
              <div class="absolute top-4 left-6 font-['Playfair_Display',serif] text-5xl text-[var(--color-accent)]/20 leading-none">"</div>
              <blockquote class="relative pt-6">
                <p class="font-['Playfair_Display',serif] italic text-lg text-[var(--color-primary-dark)] leading-relaxed" data-lang data-it={siteConfig.quote.it} data-es={siteConfig.quote.es}>
                  {siteConfig.quote.it}
                </p>
                <cite class="block mt-4 text-sm text-[var(--color-accent)] not-italic font-medium">— {siteConfig.name}</cite>
              </blockquote>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
