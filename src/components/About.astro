---
import { siteConfig } from "../config";
---

<section id="chi-sono" class="pt-20 pb-20 md:pt-24 md:pb-28 bg-black relative overflow-hidden">
  <!-- Subtle gold glow -->
  <div class="absolute top-1/2 right-0 -translate-y-1/2 w-[500px] h-[500px] bg-[var(--color-accent)]/5 blur-3xl rounded-full pointer-events-none"></div>

  <div class="max-w-5xl mx-auto px-6 relative">
    <div class="grid md:grid-cols-12 gap-10 md:gap-14 items-center">
      <!-- Oval portrait (círculo ovalado) -->
      <div class="md:col-span-5 reveal-left flex justify-center md:justify-start">
        <div class="relative">
          <!-- Outer accent ring -->
          <div class="absolute -inset-3 rounded-[50%] border-2 border-[var(--color-accent)]/30"></div>
          <!-- Oval frame -->
          <div class="relative w-64 h-80 md:w-72 md:h-96 rounded-[50%] overflow-hidden shadow-2xl shadow-black/60 border-2 border-[var(--color-accent)]/50">
            <img
              src="/profile.jpg"
              alt={siteConfig.name}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <!-- Small gold accent dot bottom-right -->
          <div class="absolute -bottom-2 -right-2 w-14 h-14 rounded-full border-2 border-[var(--color-accent)] opacity-40"></div>
        </div>
      </div>

      <!-- Content column -->
      <div class="md:col-span-7 reveal stagger-1">
        <p class="text-[var(--color-accent)] text-xs tracking-[0.25em] uppercase font-semibold mb-3" style="font-family: 'Montserrat', sans-serif;" data-lang data-it="Chi Sono" data-es="Quién Soy">Chi Sono</p>
        <div class="w-12 h-0.5 bg-[var(--color-accent)] rounded-full mb-6"></div>

        <h2 class="text-3xl md:text-4xl text-white leading-tight mb-6" style="font-family: 'Montserrat', sans-serif; font-weight: 700;">
          Drusila<br/>
          <span class="italic font-normal text-[var(--color-accent)]" style="font-family: 'Playfair Display', serif; font-weight: 500;">Miranda</span>
        </h2>

        <p class="text-white/80 leading-relaxed text-base md:text-lg" style="font-family: 'Montserrat', sans-serif; font-weight: 300;" data-lang data-it={siteConfig.about.it} data-es={siteConfig.about.es}>
          {siteConfig.about.it}
        </p>
      </div>
    </div>
  </div>
</section>
