---
import { siteConfig } from "../config";
---

<section id="hero" class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Background: warm gradient with texture -->
  <div class="absolute inset-0 bg-gradient-to-br from-[#FAF7F2] via-[#F5F0E8] to-[#EDE4D8]"></div>
  <!-- Subtle noise texture overlay -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E');"></div>

  <div class="relative max-w-6xl mx-auto px-6 py-16 md:py-0 w-full">
    <!-- Top bar: lang toggle + nav hints -->
    <div class="absolute top-6 left-6 right-6 flex items-center justify-between">
      <span class="text-xs tracking-[0.3em] uppercase text-[var(--color-primary)] font-medium">Drusila Miranda</span>
      <button id="hero-lang-toggle" class="flex items-center gap-1.5 text-xs font-semibold border border-[var(--color-primary-light)]/40 rounded-full px-4 py-1.5 hover:border-[var(--color-accent)] transition-all duration-300 bg-white/50 backdrop-blur-sm">
        <span class="hero-lang-it text-[var(--color-accent)]">IT</span>
        <span class="text-[var(--color-primary-light)]">|</span>
        <span class="hero-lang-es text-[var(--color-primary)]">ES</span>
      </button>
    </div>

    <div class="grid md:grid-cols-5 gap-8 md:gap-12 items-center pt-20 md:pt-0">
      <!-- Photo column (2/5) -->
      <div class="md:col-span-2 order-1 hero-photo">
        <div class="relative">
          <!-- Gold decorative frame offset -->
          <div class="absolute -top-3 -left-3 w-full h-full border-2 border-[var(--color-accent)]/30 rounded-2xl"></div>
          <div class="relative rounded-2xl overflow-hidden aspect-[3/4] shadow-2xl shadow-black/10">
            <img
              src="/profile.jpg"
              alt={siteConfig.name}
              class="w-full h-full object-cover"
              loading="eager"
            />
            <!-- Gradient overlay at bottom -->
            <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-black/30 to-transparent"></div>
          </div>
          <!-- Decorative gold accent -->
          <div class="absolute -bottom-4 -right-4 w-20 h-20 border-2 border-[var(--color-accent)] rounded-full opacity-40"></div>
        </div>
      </div>

      <!-- Content column (3/5) -->
      <div class="md:col-span-3 order-2">
        <p class="text-[var(--color-accent)] text-xs tracking-[0.25em] uppercase font-semibold mb-4 hero-subtitle">Creative Marketing Strategist & Meta Ads Specialist</p>

        <h1 class="font-['Playfair_Display',serif] text-5xl sm:text-6xl md:text-7xl font-bold text-[var(--color-primary-dark)] leading-[1.1] mb-6 hero-title">
          Drusila<br/>
          <span class="font-['Playfair_Display',serif] italic font-normal text-[var(--color-primary)]">Miranda</span>
        </h1>

        <p class="font-['Playfair_Display',serif] italic text-lg md:text-xl text-[var(--color-primary)] mb-4 max-w-md hero-tagline" data-lang data-it={siteConfig.tagline.it} data-es={siteConfig.tagline.es}>
          {siteConfig.tagline.it}
        </p>

        <p class="text-sm text-[var(--color-primary-dark)]/60 mb-8 max-w-md tracking-wide hero-tagline" data-lang data-it={siteConfig.positioning.it} data-es={siteConfig.positioning.es}>
          {siteConfig.positioning.it}
        </p>

        <!-- Stats row -->
        <div class="flex flex-wrap gap-8 mb-10 hero-cta">
          <div class="text-center">
            <span class="block font-['Playfair_Display',serif] text-3xl font-bold text-[var(--color-accent)]">2</span>
            <span class="text-[10px] tracking-[0.2em] uppercase text-[var(--color-primary)]" data-lang data-it="Mercati" data-es="Mercados">Mercati</span>
          </div>
          <div class="w-px bg-[var(--color-primary-light)]/30"></div>
          <div class="text-center">
            <span class="block font-['Playfair_Display',serif] text-3xl font-bold text-[var(--color-accent)]">IT/ES</span>
            <span class="text-[10px] tracking-[0.2em] uppercase text-[var(--color-primary)]" data-lang data-it="Bilingue" data-es="Bilingüe">Bilingue</span>
          </div>
          <div class="w-px bg-[var(--color-primary-light)]/30"></div>
          <div class="text-center">
            <span class="block font-['Playfair_Display',serif] text-3xl font-bold text-[var(--color-accent)]">UGC</span>
            <span class="text-[10px] tracking-[0.2em] uppercase text-[var(--color-primary)]">Content</span>
          </div>
        </div>

        <!-- CTA + Social -->
        <div class="flex flex-wrap items-center gap-6 hero-cta">
          <a
            href="#contatto"
            class="inline-flex items-center gap-2 bg-[var(--color-primary-dark)] text-[var(--color-surface-light)] px-8 py-3.5 rounded-full text-sm font-medium tracking-wide btn-hover hover:bg-[var(--color-accent)] transition-colors duration-300"
          >
            <span data-lang data-it="Parliamo" data-es="Hablemos">Parliamo</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>

          <div class="flex items-center gap-3">
            {siteConfig.social.instagram && (
              <a href={siteConfig.social.instagram} target="_blank" rel="noopener" class="w-10 h-10 rounded-full border border-[var(--color-primary-light)]/30 flex items-center justify-center text-[var(--color-primary)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-all duration-300" aria-label="Instagram">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </a>
            )}
            {siteConfig.social.tiktok && (
              <a href={siteConfig.social.tiktok} target="_blank" rel="noopener" class="w-10 h-10 rounded-full border border-[var(--color-primary-light)]/30 flex items-center justify-center text-[var(--color-primary)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-all duration-300" aria-label="TikTok">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.48V13a8.28 8.28 0 005.58 2.16v-3.45a4.85 4.85 0 01-2.65-.78l.01.01v-4.25h2.64z"/></svg>
              </a>
            )}
            {siteConfig.social.email && (
              <a href={`mailto:${siteConfig.social.email}`} class="w-10 h-10 rounded-full border border-[var(--color-primary-light)]/30 flex items-center justify-center text-[var(--color-primary)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-all duration-300" aria-label="Email">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const heroToggle = document.getElementById('hero-lang-toggle');
  let heroLang: 'it' | 'es' = 'it';

  heroToggle?.addEventListener('click', () => {
    const navToggle = document.getElementById('lang-toggle');
    if (navToggle) {
      navToggle.click();
    } else {
      document.body.classList.add('lang-switching');
      setTimeout(() => {
        heroLang = heroLang === 'it' ? 'es' : 'it';
        document.querySelectorAll('[data-lang]').forEach(el => {
          const itText = el.getAttribute('data-it');
          const esText = el.getAttribute('data-es');
          if (itText && esText) el.textContent = heroLang === 'it' ? itText : esText;
        });
        document.documentElement.lang = heroLang;
        document.body.classList.remove('lang-switching');
      }, 200);
    }
    const itLabel = heroToggle?.querySelector('.hero-lang-it');
    const esLabel = heroToggle?.querySelector('.hero-lang-es');
    const newLang = heroLang === 'it' ? 'es' : 'it';
    if (itLabel) itLabel.className = `hero-lang-it ${newLang === 'it' ? 'text-[var(--color-accent)]' : 'text-[var(--color-primary)]'}`;
    if (esLabel) esLabel.className = `hero-lang-es ${newLang === 'es' ? 'text-[var(--color-accent)]' : 'text-[var(--color-primary)]'}`;
  });
</script>
