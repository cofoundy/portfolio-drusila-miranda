---
import { siteConfig } from "../config";
---

<section id="contatto" class="py-20 md:py-28 bg-[var(--color-surface)] relative overflow-hidden">
  <!-- Decorative gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-white/50 to-transparent pointer-events-none"></div>

  <div class="max-w-3xl mx-auto px-6 text-center relative">
    <!-- Gold diamond -->
    <div class="mb-6 flex justify-center reveal">
      <div class="w-3 h-3 rotate-45 bg-[var(--color-accent)]"></div>
    </div>

    <h2 class="font-['Playfair_Display',serif] text-3xl md:text-5xl font-bold text-[var(--color-primary-dark)] mb-4 reveal stagger-1" data-lang data-it={siteConfig.cta.title.it} data-es={siteConfig.cta.title.es}>
      {siteConfig.cta.title.it}
    </h2>

    <p class="text-[var(--color-primary)] text-base md:text-lg leading-relaxed mb-10 max-w-xl mx-auto reveal stagger-2" data-lang data-it={siteConfig.cta.description.it} data-es={siteConfig.cta.description.es}>
      {siteConfig.cta.description.it}
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 reveal stagger-3">
      <a
        href={`mailto:${siteConfig.social.email}`}
        class="inline-flex items-center gap-2 bg-[var(--color-primary-dark)] text-[var(--color-surface-light)] px-10 py-4 rounded-full text-sm font-semibold btn-hover hover:bg-[var(--color-accent)] transition-colors duration-300 shadow-lg shadow-black/10"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        <span data-lang data-it={siteConfig.cta.buttonText.it} data-es={siteConfig.cta.buttonText.es}>{siteConfig.cta.buttonText.it}</span>
      </a>

      {siteConfig.social.whatsapp && (
        <a
          href={siteConfig.social.whatsapp}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 bg-white text-[var(--color-primary-dark)] px-10 py-4 rounded-full text-sm font-medium border border-[var(--color-primary-light)]/20 hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-all duration-300 shadow-sm"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      )}
    </div>

    <!-- Social row below -->
    <div class="flex items-center justify-center gap-3 mt-10 reveal stagger-4">
      {siteConfig.social.instagram && (
        <a href={siteConfig.social.instagram} target="_blank" rel="noopener" class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-[var(--color-primary)] hover:text-[var(--color-accent)] transition-colors shadow-sm" aria-label="Instagram">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
      )}
      {siteConfig.social.tiktok && (
        <a href={siteConfig.social.tiktok} target="_blank" rel="noopener" class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-[var(--color-primary)] hover:text-[var(--color-accent)] transition-colors shadow-sm" aria-label="TikTok">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.48V13a8.28 8.28 0 005.58 2.16v-3.45a4.85 4.85 0 01-2.65-.78l.01.01v-4.25h2.64z"/></svg>
        </a>
      )}
      {siteConfig.social.linktree && (
        <a href={siteConfig.social.linktree} target="_blank" rel="noopener" class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-[var(--color-primary)] hover:text-[var(--color-accent)] transition-colors shadow-sm" aria-label="Linktree">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M7.953 15.066l-.038-4.036-4.862-.002 4.162-3.594L3.066 3.16h4.6L12 7.238 16.334 3.16h4.6l-4.148 4.274 4.16 3.594-4.862.002-.038 4.036h-3.6v5.774h-1.533V15.066h-2.96z"/></svg>
        </a>
      )}
    </div>
  </div>
</section>
