---
import { siteConfig } from "../config";
---

<!-- Floating pill nav — appears on scroll -->
<nav id="floating-nav" class="fixed top-0 left-1/2 -translate-x-1/2 z-50 hidden opacity-0">
  <div class="mt-4 px-6 py-3 rounded-full border border-white/15 bg-black/85 backdrop-blur-md shadow-lg shadow-black/50 flex items-center gap-6">
    <a href="#" class="italic font-bold text-[var(--color-accent)] text-sm" style="font-family: 'Playfair Display', serif;">DM</a>

    <div class="hidden sm:flex items-center gap-4 text-sm text-white/75" style="font-family: 'Montserrat', sans-serif;">
      <a href="#servizi" class="hover:text-[var(--color-accent)] transition-colors" data-lang data-it="Servizi" data-es="Servicios">Servizi</a>
      <a href="#metodo" class="hover:text-[var(--color-accent)] transition-colors" data-lang data-it="Metodo" data-es="Método">Metodo</a>
      <a href="#portfolio" class="hover:text-[var(--color-accent)] transition-colors">Portfolio</a>
      <a href="#contatto" class="hover:text-[var(--color-accent)] transition-colors" data-lang data-it="Contatto" data-es="Contacto">Contatto</a>
    </div>

    <!-- Language Toggle -->
    <button id="lang-toggle" class="ml-2 flex items-center gap-1 text-xs font-semibold border border-white/25 rounded-full px-3 py-1 hover:border-[var(--color-accent)] transition-colors" style="font-family: 'Montserrat', sans-serif;">
      <span id="lang-label-it" class="text-[var(--color-accent)]">IT</span>
      <span class="text-white/40">/</span>
      <span id="lang-label-es" class="text-white/70">ES</span>
    </button>
  </div>
</nav>

<script>
  const nav = document.getElementById('floating-nav');

  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;
    if (scrollY > 400) {
      nav?.classList.remove('hidden');
      nav?.classList.add('header-visible');
    } else {
      nav?.classList.add('hidden');
      nav?.classList.remove('header-visible');
    }
  });

  let currentLang: 'it' | 'es' = 'it';
  const langToggle = document.getElementById('lang-toggle');
  const langLabelIt = document.getElementById('lang-label-it');
  const langLabelEs = document.getElementById('lang-label-es');

  langToggle?.addEventListener('click', () => {
    document.body.classList.add('lang-switching');

    setTimeout(() => {
      currentLang = currentLang === 'it' ? 'es' : 'it';

      document.querySelectorAll('[data-lang]').forEach(el => {
        const itText = el.getAttribute('data-it');
        const esText = el.getAttribute('data-es');
        if (itText && esText) {
          el.textContent = currentLang === 'it' ? itText : esText;
        }
      });

      if (langLabelIt && langLabelEs) {
        langLabelIt.className = currentLang === 'it' ? 'text-[var(--color-accent)]' : 'text-white/70';
        langLabelEs.className = currentLang === 'es' ? 'text-[var(--color-accent)]' : 'text-white/70';
      }

      document.documentElement.lang = currentLang;
      document.body.classList.remove('lang-switching');
    }, 200);
  });
</script>
