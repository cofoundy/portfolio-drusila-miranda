---
import { siteConfig } from "../config";
---

<section id="specializzazione" class="pt-20 pb-20 md:pt-24 md:pb-28 bg-black relative overflow-hidden">
  <!-- Subtle accent glow -->
  <div class="absolute top-0 left-0 w-96 h-96 bg-[var(--color-accent)]/5 blur-3xl rounded-full pointer-events-none"></div>

  <div class="max-w-5xl mx-auto px-6 relative">
    <div class="grid md:grid-cols-12 gap-8 md:gap-12 items-start">
      <div class="md:col-span-4 reveal-left">
        <p class="text-[var(--color-accent)] text-xs tracking-[0.25em] uppercase font-semibold mb-3" style="font-family: 'Montserrat', sans-serif;" data-lang data-it="Specializzazione" data-es="Especialidad">Specializzazione</p>
        <div class="w-12 h-0.5 bg-[var(--color-accent)] rounded-full mb-6"></div>

        <h2 class="text-3xl md:text-4xl text-white leading-tight" style="font-family: 'Montserrat', sans-serif; font-weight: 700;">
          Come <span class="italic font-normal text-[var(--color-accent)]" style="font-family: 'Playfair Display', serif; font-weight: 500;">penso</span>
        </h2>
      </div>

      <div class="md:col-span-8 reveal stagger-1">
        <p class="text-white/80 leading-relaxed text-[15px] md:text-base mb-6" style="font-family: 'Montserrat', sans-serif; font-weight: 300;" data-lang data-it={siteConfig.specialization.description.it} data-es={siteConfig.specialization.description.es}>
          {siteConfig.specialization.description.it}
        </p>

        <p class="text-white/60 text-sm mb-4 tracking-wide uppercase" style="font-family: 'Montserrat', sans-serif; font-weight: 500; letter-spacing: 0.1em;" data-lang data-it={siteConfig.specialization.intro.it} data-es={siteConfig.specialization.intro.es}>
          {siteConfig.specialization.intro.it}
        </p>

        <ul class="grid sm:grid-cols-2 gap-3 mb-8">
          {siteConfig.specialization.items.it.map((item: string, i: number) => (
            <li class="flex items-start gap-3">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] shrink-0"></span>
              <span class="text-sm text-white/80" style="font-family: 'Montserrat', sans-serif;" data-lang data-it={siteConfig.specialization.items.it[i]} data-es={siteConfig.specialization.items.es[i]}>{item}</span>
            </li>
          ))}
        </ul>

        <p class="italic text-lg md:text-xl text-[var(--color-accent)] border-l-2 border-[var(--color-accent)]/60 pl-5 leading-relaxed" style="font-family: 'Playfair Display', serif;" data-lang data-it={siteConfig.specialization.closing.it} data-es={siteConfig.specialization.closing.es}>
          {siteConfig.specialization.closing.it}
        </p>
      </div>
    </div>
  </div>
</section>
