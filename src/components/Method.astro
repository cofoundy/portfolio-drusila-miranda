---
import { siteConfig } from "../config";

const methodIcons = ["🔍", "🎯", "📱", "🧪", "📊", "💬"];
---

<section id="metodo" class="pt-10 pb-20 md:pt-14 md:pb-28 bg-[var(--color-primary-dark)] text-[var(--color-surface-light)] relative overflow-hidden">
  <!-- Decorative gradient orb -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-[var(--color-accent)]/5 blur-3xl pointer-events-none"></div>

  <div class="max-w-5xl mx-auto px-6 relative">
    <!-- Section header -->
    <div class="text-center mb-14 reveal">
      <p class="text-[var(--color-accent)] text-xs tracking-[0.25em] uppercase font-semibold mb-3" data-lang data-it="Come Lavoro" data-es="Cómo Trabajo">Come Lavoro</p>
      <h2 class="font-['Playfair_Display',serif] text-3xl md:text-4xl font-bold" data-lang data-it="Il Mio Metodo" data-es="Mi Método">Il Mio Metodo</h2>
      <div class="w-16 h-0.5 bg-gradient-to-r from-transparent via-[var(--color-accent)] to-transparent mx-auto mt-4"></div>
    </div>

    <!-- 6 steps: 3x2 grid on desktop, 2x3 on tablet, stacked on mobile -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-5">
      {siteConfig.method.map((step, i) => (
        <div class={`reveal stagger-${Math.min(i + 1, 6)} group relative bg-white/5 backdrop-blur-sm rounded-xl p-6 border border-white/10 hover:border-[var(--color-accent)]/30 transition-all duration-500 text-center`}>
          <!-- Emoji -->
          <span class="text-2xl mb-3 block">{methodIcons[i]}</span>

          <!-- Number -->
          <span class="font-['Playfair_Display',serif] text-sm font-bold text-[var(--color-accent)]/50 block mb-1">{step.number}</span>

          <!-- Title -->
          <h3 class="font-['Playfair_Display',serif] text-sm md:text-base font-bold text-[var(--color-surface-light)] leading-tight" data-lang data-it={step.title.it} data-es={step.title.es}>
            {step.title.it}
          </h3>

          {/* Connecting arrow (hidden on last item per row) */}
          {i < 5 && (
            <div class="hidden md:block absolute -right-3 top-1/2 -translate-y-1/2 text-[var(--color-accent)]/30 z-10">
              {(i + 1) % 3 !== 0 && <span class="text-lg">→</span>}
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Bottom flow arrow on mobile -->
    <div class="flex justify-center mt-6 reveal stagger-6">
      <div class="flex items-center gap-2 text-[var(--color-accent)]/40">
        <div class="w-8 h-px bg-[var(--color-accent)]/30"></div>
        <span class="text-xs tracking-[0.2em] uppercase" data-lang data-it="Risultati" data-es="Resultados">Risultati</span>
        <div class="w-8 h-px bg-[var(--color-accent)]/30"></div>
      </div>
    </div>
  </div>
</section>
