---
import { siteConfig } from "../config";

const methodIcons = ["🎯", "🔍", "🤝", "📈"];
---

<section id="metodo" class="pt-20 pb-20 md:pt-24 md:pb-28 bg-black text-white relative overflow-hidden">
  <!-- Decorative gradient orb -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-[var(--color-accent)]/5 blur-3xl pointer-events-none"></div>

  <div class="max-w-5xl mx-auto px-6 relative">
    <!-- Section header -->
    <div class="text-center mb-14 reveal">
      <p class="text-[var(--color-accent)] text-xs tracking-[0.25em] uppercase font-semibold mb-3" style="font-family: 'Montserrat', sans-serif;" data-lang data-it="Come Lavoro" data-es="Cómo Trabajo">Come Lavoro</p>
      <h2 class="text-3xl md:text-4xl text-white" style="font-family: 'Montserrat', sans-serif; font-weight: 700;" data-lang data-it="Metodologia" data-es="Metodología">
        Meto<span class="italic font-normal text-[var(--color-accent)]" style="font-family: 'Playfair Display', serif; font-weight: 500;">dologia</span>
      </h2>
      <div class="w-16 h-0.5 bg-gradient-to-r from-transparent via-[var(--color-accent)] to-transparent mx-auto mt-4"></div>
    </div>

    <!-- 4 steps: 2x2 grid -->
    <div class="grid sm:grid-cols-2 gap-5 md:gap-6">
      {siteConfig.method.map((step: any, i: number) => (
        <div class={`reveal stagger-${i + 1} group relative bg-white/[0.03] backdrop-blur-sm rounded-xl p-7 border border-white/10 hover:border-[var(--color-accent)]/40 transition-all duration-500`}>
          {/* Number + Emoji header */}
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
              <span class="text-2xl">{methodIcons[i]}</span>
              <span class="text-xs font-bold text-[var(--color-accent)]/80 tracking-[0.2em] uppercase" style="font-family: 'Montserrat', sans-serif;">{step.number}</span>
            </div>
            <span class="text-5xl font-bold text-white/5 group-hover:text-[var(--color-accent)]/15 transition-colors duration-300" style="font-family: 'Playfair Display', serif;">{step.number}</span>
          </div>

          {/* Title */}
          <h3 class="text-lg font-bold text-white mb-2" style="font-family: 'Montserrat', sans-serif;" data-lang data-it={step.title.it} data-es={step.title.es}>
            {step.title.it}
          </h3>

          {/* Description */}
          <p class="text-sm text-white/65 leading-relaxed" style="font-family: 'Montserrat', sans-serif; font-weight: 300;" data-lang data-it={step.description.it} data-es={step.description.es}>
            {step.description.it}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
