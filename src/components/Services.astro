---
import { siteConfig } from "../config";
const sistema = siteConfig.sistemaCompleto;
---

<section id="servizi" class="py-20 md:py-28 bg-black relative">
  <!-- Decorative dots -->
  <div class="absolute top-0 right-0 w-32 h-32 opacity-[0.05]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 16px 16px;"></div>
  <div class="absolute bottom-0 left-0 w-48 h-48 opacity-[0.05]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 16px 16px;"></div>

  <div class="max-w-6xl mx-auto px-6 relative">
    <!-- Section header -->
    <div class="text-center mb-14 reveal">
      <p class="text-[var(--color-accent)] text-xs tracking-[0.25em] uppercase font-semibold mb-3" style="font-family: 'Montserrat', sans-serif;" data-lang data-it="Cosa Posso Fare Per Te" data-es="Qué Puedo Hacer Por Ti">Cosa Posso Fare Per Te</p>
      <h2 class="text-3xl md:text-4xl text-white" style="font-family: 'Montserrat', sans-serif; font-weight: 700;" data-lang data-it="Servizi" data-es="Servicios">
        Ser<span class="italic font-normal text-[var(--color-accent)]" style="font-family: 'Playfair Display', serif; font-weight: 500;">vizi</span>
      </h2>
      <div class="w-16 h-0.5 bg-[var(--color-accent)] rounded-full mx-auto mt-4"></div>
    </div>

    <!-- Sistema Completo — Featured card -->
    <div class="reveal mb-10">
      <div class="relative bg-gradient-to-br from-[#0a0a0a] to-[#151515] rounded-2xl p-8 md:p-10 overflow-hidden border border-[var(--color-accent)]/30">
        <!-- Gold accent bar top -->
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-[var(--color-accent)] via-white/40 to-[var(--color-accent)]"></div>
        <!-- Subtle radial glow -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-[var(--color-accent)]/10 rounded-full blur-3xl"></div>

        <div class="relative z-10">
          <!-- Badge + Title -->
          <div class="flex flex-wrap items-center gap-3 mb-5">
            <span class="text-[10px] tracking-[0.15em] uppercase font-bold bg-[var(--color-accent)] text-black px-3 py-1.5 rounded-full" style="font-family: 'Montserrat', sans-serif;" data-lang data-it={sistema.badge.it} data-es={sistema.badge.es}>{sistema.badge.it}</span>
            <h3 class="text-2xl md:text-3xl font-bold text-white" style="font-family: 'Montserrat', sans-serif;" data-lang data-it={sistema.title.it} data-es={sistema.title.es}>{sistema.title.it}</h3>
          </div>

          <p class="text-white/75 text-sm md:text-base leading-relaxed mb-7 max-w-3xl" style="font-family: 'Montserrat', sans-serif; font-weight: 300;" data-lang data-it={sistema.description.it} data-es={sistema.description.es}>{sistema.description.it}</p>

          <div class="grid sm:grid-cols-2 gap-x-8 gap-y-3 mb-7">
            {sistema.items.it.map((item: string, i: number) => (
              <div class="flex items-start gap-3">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] shrink-0"></span>
                <span class="text-sm text-white/85" style="font-family: 'Montserrat', sans-serif;" data-lang data-it={sistema.items.it[i]} data-es={sistema.items.es[i]}>{item}</span>
              </div>
            ))}
          </div>

          <div class="flex items-center gap-3 pt-5 border-t border-white/10">
            <span class="text-[var(--color-accent)]">➡️</span>
            <p class="text-sm font-semibold text-[var(--color-accent)]" style="font-family: 'Montserrat', sans-serif;" data-lang data-it={sistema.objective.it} data-es={sistema.objective.es}>{sistema.objective.it}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Individual services header -->
    <div class="text-center mb-8 reveal">
      <p class="text-xs tracking-[0.2em] uppercase text-white/60 font-medium" style="font-family: 'Montserrat', sans-serif;" data-lang data-it="Servizi Singoli (su richiesta)" data-es="Servicios Individuales (según necesidad)">Servizi Singoli (su richiesta)</p>
    </div>

    <!-- 3 individual service cards -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {siteConfig.services.map((service: any, i: number) => (
        <div class={`group reveal stagger-${i + 1} card-hover relative bg-white/[0.03] backdrop-blur-sm rounded-2xl p-7 border border-white/10 hover:border-[var(--color-accent)]/50 overflow-hidden`}>
          <!-- Hover accent bar -->
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-[var(--color-accent)]/0 via-[var(--color-accent)] to-[var(--color-accent)]/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

          <div class="flex items-center justify-between mb-3">
            <span class="text-lg">{service.emoji}</span>
            <span class="text-4xl font-bold text-white/10 group-hover:text-[var(--color-accent)]/25 transition-colors duration-300" style="font-family: 'Playfair Display', serif;">{service.number}</span>
          </div>

          <h3 class="text-lg font-bold text-white mb-1 leading-tight" style="font-family: 'Montserrat', sans-serif;" data-lang data-it={service.title.it} data-es={service.title.es}>
            {service.title.it}
          </h3>

          {service.subtitle && (
            <p class="text-xs text-[var(--color-accent)] font-semibold mb-2" style="font-family: 'Montserrat', sans-serif;" data-lang data-it={service.subtitle.it} data-es={service.subtitle.es}>{service.subtitle.it}</p>
          )}

          <p class="text-sm text-white/65 leading-relaxed mb-4" style="font-family: 'Montserrat', sans-serif; font-weight: 300;" data-lang data-it={service.description.it} data-es={service.description.es}>
            {service.description.it}
          </p>

          <ul class="space-y-1.5 mb-4">
            {service.items.it.map((item: string, j: number) => (
              <li class="flex items-center gap-2 text-xs text-white/70">
                <span class="w-1 h-1 rounded-full bg-[var(--color-accent)] shrink-0"></span>
                <span style="font-family: 'Montserrat', sans-serif;" data-lang data-it={service.items.it[j]} data-es={service.items.es[j]}>{item}</span>
              </li>
            ))}
          </ul>

          <div class="pt-3 border-t border-white/10">
            <div class="flex items-center gap-2">
              <span class="text-[var(--color-accent)] text-xs">➡️</span>
              <span class="text-xs font-semibold text-[var(--color-accent)]" style="font-family: 'Montserrat', sans-serif;" data-lang data-it={service.result.it} data-es={service.result.es}>{service.result.it}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
