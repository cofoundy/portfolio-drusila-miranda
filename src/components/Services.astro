---
import { siteConfig } from "../config";
---

<section id="servizi" class="py-20 md:py-28 bg-[var(--color-surface)] relative">
  <!-- Decorative dots -->
  <div class="absolute top-0 right-0 w-32 h-32 opacity-[0.04]" style="background-image: radial-gradient(circle, var(--color-primary-dark) 1px, transparent 1px); background-size: 16px 16px;"></div>
  <div class="absolute bottom-0 left-0 w-48 h-48 opacity-[0.04]" style="background-image: radial-gradient(circle, var(--color-primary-dark) 1px, transparent 1px); background-size: 16px 16px;"></div>

  <div class="max-w-6xl mx-auto px-6">
    <!-- Section header -->
    <div class="text-center mb-14 reveal">
      <p class="text-[var(--color-accent)] text-xs tracking-[0.25em] uppercase font-semibold mb-3" data-lang data-it="Cosa Posso Fare Per Te" data-es="Qué Puedo Hacer Por Ti">Cosa Posso Fare Per Te</p>
      <h2 class="font-['Playfair_Display',serif] text-3xl md:text-4xl font-bold text-[var(--color-primary-dark)]" data-lang data-it="Servizi" data-es="Servicios">Servizi</h2>
      <div class="w-16 h-0.5 bar-shimmer rounded-full mx-auto mt-4"></div>
    </div>

    <!-- 6 service cards: 2x3 grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {siteConfig.services.map((service, i) => (
        <div class={`group reveal stagger-${Math.min(i + 1, 6)} card-hover relative bg-white rounded-2xl p-7 border ${(service as any).highlight ? 'border-[var(--color-accent)]/30' : (service as any).premium ? 'border-[var(--color-accent)]' : 'border-[var(--color-primary-light)]/15'} hover:border-[var(--color-accent)]/50 overflow-hidden`}>

          {/* Top accent bar */}
          <div class={`absolute top-0 left-0 right-0 h-1 ${(service as any).premium ? 'bg-gradient-to-r from-[var(--color-accent)] via-[var(--color-primary-light)] to-[var(--color-accent)]' : 'bg-gradient-to-r from-[var(--color-accent)]/0 via-[var(--color-accent)] to-[var(--color-accent)]/0 opacity-0 group-hover:opacity-100'} transition-opacity duration-500`}></div>

          {/* Badges */}
          <div class="flex items-center gap-2 mb-4">
            {(service as any).highlight && (
              <span class="text-[9px] tracking-[0.15em] uppercase font-bold bg-[var(--color-accent)]/10 text-[var(--color-accent)] px-2.5 py-1 rounded-full" data-lang data-it="Differenziatore" data-es="Diferenciador">Differenziatore</span>
            )}
            {(service as any).premium && (
              <span class="text-[9px] tracking-[0.15em] uppercase font-bold bg-[var(--color-primary-dark)] text-[var(--color-accent)] px-2.5 py-1 rounded-full">Premium</span>
            )}
          </div>

          {/* Number + Emoji */}
          <div class="flex items-center justify-between mb-3">
            <span class="text-lg">{(service as any).emoji}</span>
            <span class="font-['Playfair_Display',serif] text-4xl font-bold text-[var(--color-surface)] group-hover:text-[var(--color-accent)]/10 transition-colors duration-300">{service.number}</span>
          </div>

          {/* Title */}
          <h3 class="font-['Playfair_Display',serif] text-lg font-bold text-[var(--color-primary-dark)] mb-2 leading-tight" data-lang data-it={service.title.it} data-es={service.title.es}>
            {service.title.it}
          </h3>

          {/* Description */}
          <p class="text-sm text-[var(--color-primary)] leading-relaxed mb-4" data-lang data-it={service.description.it} data-es={service.description.es}>
            {service.description.it}
          </p>

          {/* Items */}
          <ul class="space-y-1.5 mb-4">
            {service.items.it.map((item: string, j: number) => (
              <li class="flex items-center gap-2 text-xs text-[var(--color-primary-dark)]/70">
                <span class="w-1 h-1 rounded-full bg-[var(--color-accent)] shrink-0"></span>
                <span data-lang data-it={service.items.it[j]} data-es={service.items.es[j]}>{item}</span>
              </li>
            ))}
          </ul>

          {/* Duration badge */}
          <div class="pt-3 border-t border-[var(--color-surface)]">
            <span class="inline-flex items-center gap-1.5 text-[10px] tracking-[0.1em] uppercase text-[var(--color-primary)] font-medium">
              <svg class="w-3 h-3 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span data-lang data-it={service.duration.it} data-es={service.duration.es}>{service.duration.it}</span>
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
