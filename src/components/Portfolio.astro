---
import { siteConfig } from "../config";

// Categories she works in (from Linktree + WhatsApp)
const categories = [
  { label: { it: "B&B & Hospitality", es: "B&B & Hospitalidad" }, status: "wip" },
  { label: { it: "Food & Lifestyle", es: "Food & Lifestyle" }, status: "soon" },
  { label: { it: "Beauty & Wellness", es: "Belleza & Bienestar" }, status: "soon" },
];
---

<section id="portfolio" class="py-20 md:py-28 bg-white relative">
  <div class="max-w-5xl mx-auto px-6">
    <!-- Section header -->
    <div class="text-center mb-14 reveal">
      <p class="text-[var(--color-accent)] text-xs tracking-[0.25em] uppercase font-semibold mb-3">Portfolio</p>
      <h2 class="font-['Playfair_Display',serif] text-3xl md:text-4xl font-bold text-[var(--color-primary-dark)]" data-lang data-it="Casi di Studio" data-es="Casos de Estudio">Casi di Studio</h2>
      <div class="w-16 h-0.5 bar-shimmer rounded-full mx-auto mt-4"></div>
    </div>

    <!-- Category cards grid -->
    <div class="grid sm:grid-cols-3 gap-6 mb-12 reveal stagger-1">
      {categories.map((cat) => (
        <div class="group relative bg-[var(--color-surface)] rounded-2xl p-8 text-center border border-[var(--color-primary-light)]/10 hover:border-[var(--color-accent)]/30 transition-all duration-300">
          <!-- Status badge -->
          <div class="inline-flex items-center gap-1.5 bg-white rounded-full px-3 py-1 mb-5">
            <span class={`w-2 h-2 rounded-full ${cat.status === 'wip' ? 'bg-[var(--color-accent)] animate-pulse' : 'bg-[var(--color-primary-light)]/40'}`}></span>
            <span class="text-[10px] tracking-[0.15em] uppercase text-[var(--color-primary)] font-medium">
              {cat.status === 'wip' ? 'In Progress' : 'Coming Soon'}
            </span>
          </div>

          <!-- Category icon placeholder (decorative) -->
          <div class="w-16 h-16 mx-auto mb-4 rounded-xl bg-white flex items-center justify-center">
            <div class="w-8 h-8 border-2 border-dashed border-[var(--color-primary-light)]/30 rounded-lg flex items-center justify-center">
              <span class="text-[var(--color-accent)] text-lg">✦</span>
            </div>
          </div>

          <!-- Category name -->
          <h3 class="font-['Playfair_Display',serif] text-lg font-bold text-[var(--color-primary-dark)]" data-lang data-it={cat.label.it} data-es={cat.label.es}>
            {cat.label.it}
          </h3>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center reveal stagger-2">
      <div class="inline-flex items-center gap-3 bg-[var(--color-surface)] rounded-full px-6 py-3">
        <div class="w-2 h-2 rounded-full bg-[var(--color-accent)] animate-pulse"></div>
        <p class="text-sm text-[var(--color-primary)]" data-lang data-it="I miei primi progetti sono in corso. Vuoi essere il prossimo?" data-es="Mis primeros proyectos están en curso. ¿Quieres ser el próximo?">
          I miei primi progetti sono in corso. Vuoi essere il prossimo?
        </p>
        <a href="#contatto" class="text-[var(--color-accent)] font-semibold text-sm hover:underline" data-lang data-it="Contattami →" data-es="Contáctame →">Contattami →</a>
      </div>
    </div>
  </div>
</section>
