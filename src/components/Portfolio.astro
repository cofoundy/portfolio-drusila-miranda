---
import { siteConfig } from "../config";
---

<section id="portfolio" class="py-20 md:py-28 bg-[var(--color-surface)]">
  <div class="max-w-5xl mx-auto px-6">
    <!-- Section header -->
    <div class="mb-14 reveal">
      <p class="text-[var(--color-accent)] text-xs tracking-widest uppercase mb-3 font-semibold">Portfolio</p>
      <div class="w-12 h-0.5 bar-shimmer rounded-full"></div>
    </div>

    <!-- Coming Soon placeholder (elegant) -->
    <div class="reveal stagger-1">
      <div class="max-w-xl mx-auto text-center py-16 px-8 border border-dashed border-[var(--color-primary-light)]/40 rounded-2xl bg-white/50">
        <!-- Decorative gold diamond -->
        <div class="mb-6 flex justify-center">
          <div class="w-3 h-3 rotate-45 bg-[var(--color-accent)]"></div>
        </div>

        <h3 class="font-['Playfair_Display',serif] italic text-2xl text-[var(--color-primary)] mb-4" data-lang data-it="In Arrivo" data-es="Próximamente">
          In Arrivo
        </h3>

        <p class="text-sm text-[var(--color-primary)]/70 leading-relaxed mb-8 max-w-sm mx-auto" data-lang data-it={siteConfig.portfolio.comingSoon.it} data-es={siteConfig.portfolio.comingSoon.es}>
          {siteConfig.portfolio.comingSoon.it}
        </p>

        <a
          href="#contatto"
          class="inline-flex items-center gap-2 text-sm text-[var(--color-accent)] font-medium hover:text-[var(--color-primary-dark)] transition-colors link-underline"
        >
          <span data-lang data-it="Contattami per saperne di più" data-es="Contáctame para saber más">Contattami per saperne di più</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
