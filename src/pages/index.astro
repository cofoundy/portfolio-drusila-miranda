---
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Services from "../components/Services.astro";
import Method from "../components/Method.astro";
import Portfolio from "../components/Portfolio.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import { siteConfig } from "../config";
import "../styles/global.css";
---

<html lang="it" style={`--color-primary-dark:${siteConfig.colors.primaryDark};--color-primary:${siteConfig.colors.primary};--color-primary-light:${siteConfig.colors.primaryLight};--color-accent:${siteConfig.colors.accent};--color-surface:${siteConfig.colors.surface};--color-surface-light:${siteConfig.colors.surfaceLight}`}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={siteConfig.description.it} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${siteConfig.name} — ${siteConfig.title}`} />
    <meta property="og:description" content={siteConfig.description.it} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://drusila-miranda.cofoundy.dev/og.jpg" />

    <!-- Fonts: Playfair Display + Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500;1,600&display=swap"
      rel="stylesheet"
    />

    <title>{siteConfig.name} — {siteConfig.title}</title>
  </head>
  <body class="bg-[var(--color-surface-light)]">
    <Nav />
    <main>
      <Hero />

      <!-- Hero → About: gold accent divider -->
      <div class="relative h-24 bg-white">
        <div class="absolute inset-x-0 top-0 h-full bg-gradient-to-b from-[var(--color-surface)] to-white"></div>
        <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 flex items-center gap-4">
          <div class="w-16 h-px bg-gradient-to-r from-transparent to-[var(--color-accent)]/40"></div>
          <div class="w-2 h-2 rotate-45 bg-[var(--color-accent)]/30"></div>
          <div class="w-16 h-px bg-gradient-to-l from-transparent to-[var(--color-accent)]/40"></div>
        </div>
      </div>

      <About />

      <!-- About → Services: subtle gradient blend -->
      <div class="h-16 bg-gradient-to-b from-white to-[var(--color-surface)]"></div>

      <Services />

      <!-- Services → Method: dramatic light-to-dark transition -->
      <div class="relative h-32">
        <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-surface)] via-[#3a3028] to-[var(--color-primary-dark)]"></div>
        <div class="absolute inset-x-0 top-1/2 -translate-y-1/2 flex justify-center">
          <div class="flex items-center gap-3">
            <div class="w-20 h-px bg-gradient-to-r from-transparent to-[var(--color-accent)]/50"></div>
            <div class="w-2.5 h-2.5 rotate-45 border border-[var(--color-accent)]/50"></div>
            <div class="w-20 h-px bg-gradient-to-l from-transparent to-[var(--color-accent)]/50"></div>
          </div>
        </div>
      </div>

      <Method />

      <!-- Method → Portfolio: dark-to-light transition -->
      <div class="relative h-32">
        <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-primary-dark)] via-[#3a3028] to-white"></div>
        <div class="absolute inset-x-0 top-1/2 -translate-y-1/2 flex justify-center">
          <div class="flex items-center gap-3">
            <div class="w-20 h-px bg-gradient-to-r from-transparent to-[var(--color-accent)]/50"></div>
            <div class="w-2.5 h-2.5 rotate-45 border border-[var(--color-accent)]/50"></div>
            <div class="w-20 h-px bg-gradient-to-l from-transparent to-[var(--color-accent)]/50"></div>
          </div>
        </div>
      </div>

      <Portfolio />

      <!-- Portfolio → Contact: soft blend -->
      <div class="h-16 bg-gradient-to-b from-white to-[var(--color-surface)]"></div>

      <Contact />

      <!-- Contact → Footer: blend to dark -->
      <div class="h-16 bg-gradient-to-b from-[var(--color-surface)] to-[var(--color-primary-dark)]"></div>
    </main>
    <Footer />

    <!-- Scroll Reveal -->
    <script>
      const observerOptions = {
        root: null,
        rootMargin: '0px 0px -10% 0px',
        threshold: 0.1
      };

      const revealOnScroll = (entries: IntersectionObserverEntry[], observer: IntersectionObserver) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      };

      const observer = new IntersectionObserver(revealOnScroll, observerOptions);

      document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale').forEach(el => {
        observer.observe(el);
      });
    </script>
  </body>
</html>
