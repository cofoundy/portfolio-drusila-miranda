---
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Specialization from "../components/Specialization.astro";
import About from "../components/About.astro";
import Skills from "../components/Skills.astro";
import Services from "../components/Services.astro";
import Method from "../components/Method.astro";
import Portfolio from "../components/Portfolio.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import { siteConfig } from "../config";
import "../styles/global.css";
---

<html lang="it" style={`--color-primary-dark:${siteConfig.colors.primaryDark};--color-primary:${siteConfig.colors.primary};--color-primary-light:${siteConfig.colors.primaryLight};--color-accent:${siteConfig.colors.accent};--color-surface:${siteConfig.colors.surface};--color-surface-light:${siteConfig.colors.surfaceLight}`}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={siteConfig.description.it} />
    <meta name="theme-color" content="#000000" />

    <!-- Open Graph -->
    <meta property="og:title" content={`${siteConfig.name} — ${siteConfig.title}`} />
    <meta property="og:description" content={siteConfig.description.it} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://drusilamiranda.com/og.jpg" />

    <!-- Fonts: Montserrat (primary) + Playfair Display (accent) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&display=swap"
      rel="stylesheet"
    />

    <title>{siteConfig.name} — {siteConfig.title}</title>
  </head>
  <body class="bg-black text-white" style="font-family: 'Montserrat', sans-serif;">
    <Nav />
    <main class="bg-black">
      <Hero />
      <Specialization />
      <About />
      <Skills />
      <Method />
      <Services />
      <Portfolio />
      <Contact />
    </main>
    <Footer />

    <!-- Scroll Reveal -->
    <script>
      const observerOptions = {
        root: null,
        rootMargin: '0px 0px -10% 0px',
        threshold: 0.1
      };

      const revealOnScroll = (entries: IntersectionObserverEntry[], observer: IntersectionObserver) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      };

      const observer = new IntersectionObserver(revealOnScroll, observerOptions);

      document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale').forEach(el => {
        observer.observe(el);
      });
    </script>
  </body>
</html>
